{
  "family": "nutritrack-backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/LabRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/LabRole",
  "containerDefinitions": [
    {
      "name": "nutritrack-backend",
      "image": "<ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com/nutritrack-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        { "name": "DB_URL", "value": "jdbc:postgresql://<rds-endpoint>:5432/nutritrack_db" },
        { "name": "DB_USER", "value": "postgres" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "AWS_S3_BUCKET", "value": "nutritrack-certificates" },
        { "name": "EMAIL_FROM", "value": "onboarding@resend.dev" },
        { "name": "CORS_ORIGINS", "value": "http://localhost:5173" }
      ],
      "secrets": [
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/nutritrack/db_password" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/nutritrack/jwt_secret" },
        { "name": "RESEND_API_KEY", "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/nutritrack/resend_api_key" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/nutritrack-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
